<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="report_vhg_profit_and_loss" model="account.report">
        <field name="name">VHG Profit and Loss (VTR Format)</field>
        <field name="filter_analytic_groupby" eval="True"/>
        <field name="filter_unfold_all" eval="True"/>
        <field name="filter_journals" eval="True"/>
        <field name="filter_period_comparison" eval="True"/>
        <field name="filter_multi_company">selector</field>
        <field name="filter_budgets" eval="True"/>
        <field name="allow_account_audit_status_on_lines" eval="True"/>
        <field name="default_opening_date_filter">this_month</field>
        <field name="custom_handler_model_id" ref="model_tha_vhg_pnl_report_handler"/>
        <field name="column_ids">
            <record id="report_vhg_profit_and_loss_balance" model="account.report.column">
                <field name="name">Balance</field>
                <field name="expression_label">balance</field>
            </record>
        </field>
    </record>

    <record id="action_report_vhg_profit_and_loss" model="ir.actions.client">
        <field name="name">VHG Profit and Loss (VTR Format)</field>
        <field name="tag">account_report</field>
        <field name="path">vhg-profit-and-loss-vtr</field>
        <field name="context" eval="{'report_id': ref('tha_vhg_pnl_ext.report_vhg_profit_and_loss')}"/>
    </record>

    <menuitem
        id="menu_action_report_vhg_profit_and_loss"
        name="VHG Profit and Loss (VTR Format)"
        action="action_report_vhg_profit_and_loss"
        parent="account.account_reports_legal_statements_menu"
        groups="account.group_account_readonly"
        sequence="15"/>
</odoo>
