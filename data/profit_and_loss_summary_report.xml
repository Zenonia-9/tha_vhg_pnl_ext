<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="report_vhg_profit_and_loss_summary" model="account.report">
        <field name="name">Management Profit and Loss Summary</field>
        <field name="filter_analytic_groupby" eval="True"/>
        <field name="filter_unfold_all" eval="False"/>
        <field name="filter_journals" eval="True"/>
        <field name="filter_period_comparison" eval="False"/>
        <field name="filter_multi_company">selector</field>
        <field name="filter_budgets" eval="True"/>
        <field name="default_opening_date_filter">this_month</field>
        <field name="custom_handler_model_id" ref="model_tha_vhg_pnl_summary_report_handler"/>
        <field name="column_ids">
            <record id="report_vhg_profit_and_loss_summary_balance" model="account.report.column">
                <field name="name">Balance</field>
                <field name="expression_label">balance</field>
            </record>
        </field>
    </record>

    <record id="action_report_vhg_profit_and_loss_summary" model="ir.actions.client">
        <field name="name">Management Profit and Loss Summary</field>
        <field name="tag">account_report</field>
        <field name="path">vhg-profit-and-loss-summary</field>
        <field name="context" eval="{'report_id': ref('tha_vhg_pnl_ext.report_vhg_profit_and_loss_summary')}"/>
    </record>

    <menuitem
        id="menu_action_report_vhg_profit_and_loss_summary"
        name="Management Profit and Loss Summary"
        action="action_report_vhg_profit_and_loss_summary"
        parent="account.account_reports_legal_statements_menu"
        groups="account.group_account_readonly"
        sequence="16"/>
</odoo>
